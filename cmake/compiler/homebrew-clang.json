{
    "version": 7,
    "configurePresets": [
        {
            "name": "compiler-homebrew-clang",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": true,
                "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm@21/bin/clang++",
                "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm@21/bin/clang",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Werror -pedantic",
                "CMAKE_C_FLAGS": "-Wall -Wextra -Werror -pedantic"
            },
            "environment": {
                "SDKROOT": "/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk"
            }
        }
    ]
}