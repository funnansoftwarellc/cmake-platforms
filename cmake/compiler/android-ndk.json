{
    "version": 7,
    "configurePresets": [
        {
            "name": "compiler-android-ndk",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": true,
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Werror -pedantic",
                "CMAKE_C_FLAGS": "-Wall -Wextra -Werror -pedantic",
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake"
            }
        }
    ]
}