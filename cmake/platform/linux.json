{
    "version": 7,
    "include": [
        "../compiler/clang.json",
        "../compiler/gcc.json",
        "../config/binaryDir.json",
        "../config/debug.json",
        "../config/ninja.json",
        "../config/release.json",
        "../config/vcpkg.json",
        "../host/x64-linux.json",
        "../target/x64-linux.json"
    ],
    "configurePresets": [
        {
            "name": "x64-linux-gcc-debug",
            "inherits": [
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "compiler-gcc",
                "host-x64-linux",
                "target-x64-linux"
            ]
        },
        {
            "name": "x64-linux-gcc-release",
            "inherits": [
                "config-binaryDir",
                "config-release",
                "config-ninja",
                "config-vcpkg",
                "compiler-gcc",
                "host-x64-linux",
                "target-x64-linux"
            ]
        },
        {
            "name": "x64-linux-clang-debug",
            "inherits": [
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "compiler-clang",
                "host-x64-linux",
                "target-x64-linux"
            ]
        },
        {
            "name": "x64-linux-clang-release",
            "inherits": [
                "config-binaryDir",
                "config-release",
                "config-ninja",
                "config-vcpkg",
                "compiler-clang",
                "host-x64-linux",
                "target-x64-linux"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "x64-linux-gcc-debug",
            "configurePreset": "x64-linux-gcc-debug"
        },
        {
            "name": "x64-linux-gcc-release",
            "configurePreset": "x64-linux-gcc-release"
        },
        {
            "name": "x64-linux-clang-debug",
            "configurePreset": "x64-linux-clang-debug"
        },
        {
            "name": "x64-linux-clang-release",
            "configurePreset": "x64-linux-clang-release"
        }
    ],
    "testPresets": [
        {
            "name": "x64-linux-gcc-debug",
            "configurePreset": "x64-linux-gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-linux-gcc-release",
            "configurePreset": "x64-linux-gcc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-linux-clang-debug",
            "configurePreset": "x64-linux-clang-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-linux-clang-release",
            "configurePreset": "x64-linux-clang-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}